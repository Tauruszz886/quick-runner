{
  "name": "quick-runner",
  "version": "1.0.0",
  "description": "Eggitor map workspace template",
  "engines": {
    "node": ">=16.10.0"
  },
  "scripts": {
    "build": "tstl && cp .luarc.json project/ts_out/",
    "generate:terrain": "python3 tools/zlj_data/generate_level_terrain.py --workspace .",
    "watch": "tstl --watch"
  },
  "_disabledScriptsComment": "package.json 不支持 JSON 注释；这里保留暂不启用的脚本，安装 lua-language-server 后可移回 scripts。",
  "_disabledScripts": {
    "lint": "lua-language-server --check project/ts_out --checklevel=Error",
    "lint:warn": "lua-language-server --check project/ts_out --checklevel=Warning"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "typescript-to-lua": "1.33.2"
  }
}
